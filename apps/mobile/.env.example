# Copy this file to apps/mobile/.env and fill in real values.
# Expo's CLI auto-loads .env from this directory at `expo start` and
# `expo export` time; app.config.ts reads the vars and bakes them into
# Constants.expoConfig.extra.firebaseConfig.
#
# Firebase Web SDK config values (apiKey, projectId, etc.) are NOT secrets
# per https://firebase.google.com/docs/projects/api-keys — security is
# enforced by Firestore/Storage rules and (optionally) App Check.
#
# Mirror of apps/web/.env.example but without the NEXT_PUBLIC_ prefix,
# because Expo's CLI runs Node directly when evaluating app.config.ts
# and exposes process.env without a prefix filter.
#
# Get values from:
#   Firebase console → <project> → ⚙ Project settings → General → Your apps
#   → Web app → "SDK setup and configuration".

# Active environment. One of: dev, beta, prod
APP_ENV=dev

# ─── DEV (villa-events) ──────────────────────────────────────────────────────
FIREBASE_API_KEY_DEV=
FIREBASE_AUTH_DOMAIN_DEV=
FIREBASE_PROJECT_ID_DEV=
FIREBASE_STORAGE_BUCKET_DEV=
FIREBASE_MESSAGING_SENDER_ID_DEV=
FIREBASE_APP_ID_DEV=

# ─── BETA (cultuvilla-beta) ──────────────────────────────────────────────────
FIREBASE_API_KEY_BETA=
FIREBASE_AUTH_DOMAIN_BETA=
FIREBASE_PROJECT_ID_BETA=
FIREBASE_STORAGE_BUCKET_BETA=
FIREBASE_MESSAGING_SENDER_ID_BETA=
FIREBASE_APP_ID_BETA=

# ─── PROD (cultuvilla-prod) ──────────────────────────────────────────────────
FIREBASE_API_KEY_PROD=
FIREBASE_AUTH_DOMAIN_PROD=
FIREBASE_PROJECT_ID_PROD=
FIREBASE_STORAGE_BUCKET_PROD=
FIREBASE_MESSAGING_SENDER_ID_PROD=
FIREBASE_APP_ID_PROD=

# EAS project id (only needed for `eas build` / `eas update`). Leave empty for
# local dev with Expo Go.
EAS_PROJECT_ID=
