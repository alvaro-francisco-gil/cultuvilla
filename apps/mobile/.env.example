# Copy this file to apps/mobile/.env and fill in real values.
# Expo's CLI auto-loads .env from this directory at `expo start` and
# `expo export` time; app.config.ts reads the vars and bakes them into
# Constants.expoConfig.extra.firebaseConfig / extra.googleSignIn.
#
# Firebase Web SDK config values (apiKey, projectId, etc.) are NOT secrets
# per https://firebase.google.com/docs/projects/api-keys — security is
# enforced by Firestore/Storage rules and (optionally) App Check.
#
# Get Firebase values from:
#   Firebase console → <project> → ⚙ Project settings → General → Your apps
#   → Web app → "SDK setup and configuration".

# Active environment. One of: dev, beta, prod
APP_ENV=dev

# ─── Firebase — DEV (villa-events) ───────────────────────────────────────────
FIREBASE_API_KEY_DEV=
FIREBASE_AUTH_DOMAIN_DEV=
FIREBASE_PROJECT_ID_DEV=
FIREBASE_STORAGE_BUCKET_DEV=
FIREBASE_MESSAGING_SENDER_ID_DEV=
FIREBASE_APP_ID_DEV=

# ─── Firebase — BETA (cultuvilla-beta) ───────────────────────────────────────
FIREBASE_API_KEY_BETA=
FIREBASE_AUTH_DOMAIN_BETA=
FIREBASE_PROJECT_ID_BETA=
FIREBASE_STORAGE_BUCKET_BETA=
FIREBASE_MESSAGING_SENDER_ID_BETA=
FIREBASE_APP_ID_BETA=

# ─── Firebase — PROD (cultuvilla-prod) ───────────────────────────────────────
FIREBASE_API_KEY_PROD=
FIREBASE_AUTH_DOMAIN_PROD=
FIREBASE_PROJECT_ID_PROD=
FIREBASE_STORAGE_BUCKET_PROD=
FIREBASE_MESSAGING_SENDER_ID_PROD=
FIREBASE_APP_ID_PROD=

# EAS project id (only needed for `eas build` / `eas update`). Set by `eas init`.
EAS_PROJECT_ID=

# ─── Google Sign-In OAuth client IDs ─────────────────────────────────────────
# Create three OAuth 2.0 Client IDs per env in the matching project at
#   https://console.cloud.google.com/apis/credentials
# (1) Web client — webClientId. Used by Firebase to verify the idToken.
# (2) iOS client — bundle id must match app.config.ts bundleIdPerEnv.
#     The "iOS URL scheme" value (com.googleusercontent.apps.<reversed-id>)
#     goes into GOOGLE_IOS_URL_SCHEME_*.
# (3) Android client — package name must match bundleIdPerEnv + SHA-1
#     fingerprint must match the signing key (EAS prints it on first build;
#     `eas credentials` shows it later). Not referenced from JS — Google
#     matches on package+signature.
# In Firebase console → Authentication → Sign-in method → Google → Web
# SDK configuration, the "Web client ID" must match GOOGLE_WEB_CLIENT_ID_*.
GOOGLE_WEB_CLIENT_ID_DEV=
GOOGLE_IOS_CLIENT_ID_DEV=
GOOGLE_IOS_URL_SCHEME_DEV=

GOOGLE_WEB_CLIENT_ID_BETA=
GOOGLE_IOS_CLIENT_ID_BETA=
GOOGLE_IOS_URL_SCHEME_BETA=

GOOGLE_WEB_CLIENT_ID_PROD=
GOOGLE_IOS_CLIENT_ID_PROD=
GOOGLE_IOS_URL_SCHEME_PROD=

# ─── Dev auto sign-in (DEV builds only) ──────────────────────────────────────
# When both are set in a `dev` build (APP_ENV=dev), the app signs straight into
# this account on launch instead of the email-link round-trip — handy on the
# Android emulator. Ignored in beta/prod (app.config.ts only wires it for dev)
# and double-gated behind __DEV__ in AuthContext, so it can never ship.
# Use a seeded demo account (see `pnpm seed:dev:users`), e.g.:
#   DEV_AUTOLOGIN_EMAIL=demo-vecino@cultuvilla.dev   # regular resident
#   DEV_AUTOLOGIN_EMAIL=demo-admin@cultuvilla.dev    # app admin
#   DEV_AUTOLOGIN_PASSWORD=cultuvilla-dev
# Leave both blank/commented to get the normal login screen. To test the
# guest/logged-out flow with the flag on, sign out in-app (stays out until reload).
DEV_AUTOLOGIN_EMAIL=
DEV_AUTOLOGIN_PASSWORD=

# ─── Expo / EAS ──────────────────────────────────────────────────────────────
# Robot-user access token for this repo. With this set, eas-cli operations
# run from apps/mobile/ act as the cultuvilla Expo account/org, overriding
# the globally-logged-in account (`eas whoami` without this var).
# Create at: https://expo.dev/accounts/<your-account>/settings/access-tokens
# (or via a robot user → Create token). NEVER commit a real value here.
EXPO_TOKEN=
