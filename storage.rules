rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Reference-data escudos (coats of arms) — public, written only by
    // admin SDK from scripts/upload-escudos.mjs, never by clients.
    match /municipalities/{municipalityId}/escudo.webp {
      allow read: if true;
      allow write: if false;
    }
    match /municipalities/{municipalityId}/escudo-thumb.webp {
      allow read: if true;
      allow write: if false;
    }

    // Community cover images uploaded by village admins via
    // imageService.uploadMunicipalityImage (villageId === municipalityId).
    match /municipalities/{municipalityId}/images/{imageId} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Event cover images uploaded via imageService.uploadEventImage, scoped to
    // the event's owning municipality.
    match /municipalities/{municipalityId}/events/{eventId}/image/{imageId} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    match /users/{userId}/photo/{imageId} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    match /users/{userId}/personas/{personaId}/photo/{imageId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // A person photo can be managed by whoever may edit the person doc itself.
    // Mirror firestore.rules /persons/{personId} update: the linked account
    // owner (userId == uid), or the creator while no account is linked. The
    // bare `createdBy == uid` check broke seed/migrated self-persons, whose
    // `createdBy` is the seed but whose `userId` is the real owner.
    function personOwnsPhoto(personId) {
      return firestore.get(/databases/(default)/documents/persons/$(personId)).data.userId == request.auth.uid
             || (firestore.get(/databases/(default)/documents/persons/$(personId)).data.createdBy == request.auth.uid
                 && firestore.get(/databases/(default)/documents/persons/$(personId)).data.userId == null);
    }

    match /persons/{personId}/photos/{imageId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*')
                   && personOwnsPhoto(personId);
      allow delete: if request.auth != null
                    && personOwnsPhoto(personId);
    }

    // News post images. Mirrors the event/org/place image rules: gate on auth +
    // size + content-type, not a cross-service firestore.get. The news doc is
    // created milliseconds before its images upload, and a Storage-rules
    // firestore.get races that just-committed write (sees null -> 403). The
    // authoring guard lives on the news doc write in firestore.rules; the
    // storage path is keyed by post id, same as events.
    match /news/{postId}/images/{imageId} {
      // News is public, shareable content (public /news/:id links) — reads are
      // public, mirroring event/org/place images. Anonymous visitors opening a
      // shared link must be able to load the image, not just the text.
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null;
    }

    match /organizations/{organizationId}/image/{imageId} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    match /municipalities/{municipalityId}/places/{placeId}/image/{imageId} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    match /municipalities/{municipalityId}/barrios/{barrioId}/image/{imageId} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    match /festivalPosters/{municipalityId}/{posterId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
  }
}
