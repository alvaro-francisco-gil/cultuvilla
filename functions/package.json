{
  "name": "cultuvilla-functions",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.test.json",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.config.integration.mjs",
    "test:watch": "vitest",
    "serve": "npm run build && firebase emulators:start --only functions",
    "deploy": "firebase deploy --only functions",
    "test:all": "vitest run --config vitest.config.all.mjs",
    "lint": "eslint . --max-warnings 0 --no-error-on-unmatched-pattern"
  },
  "engines": {
    "node": "22"
  },
  "dependencies": {
    "@cultuvilla/shared": "file:../packages/shared",
    "firebase-admin": "^13.0.0",
    "firebase-functions": "^7.2.5"
  },
  "devDependencies": {
    "eslint": "^9.39.4",
    "firebase-functions-test": "^3.5.0",
    "globals": "^17.6.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.60.0",
    "vitest": "^4.0.15"
  }
}
