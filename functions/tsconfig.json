{
  "compilerOptions": {
    "module": "node16",
    "moduleResolution": "node16",
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "outDir": "dist",
    "sourceMap": true,
    "strict": true,
    "target": "ES2020",
    "skipLibCheck": true,
    "rootDir": "src"
  },
  "compileOnSave": true,
  "include": ["src"],
  "exclude": ["src/__tests__"]
}
