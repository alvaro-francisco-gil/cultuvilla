{
  "name": "@cultuvilla/shared",
  "version": "0.1.0",
  "private": true,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./firebase/refs/client": {
      "types": "./dist/firebase/refs/client.d.ts",
      "default": "./dist/firebase/refs/client.js"
    },
    "./firebase/refs/admin": {
      "types": "./dist/firebase/refs/admin.d.ts",
      "default": "./dist/firebase/refs/admin.js"
    },
    "./models": {
      "types": "./dist/models/index.d.ts",
      "default": "./dist/models/index.js"
    }
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.config.integration.ts",
    "test:rules": "vitest run --config vitest.config.e2e.ts",
    "test:all": "vitest run --config vitest.config.all.ts",
    "test:coverage": "vitest run --coverage",
    "test:coverage:all": "vitest run --config vitest.config.all.ts --coverage",
    "lint": "eslint . --max-warnings 0"
  },
  "dependencies": {
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "firebase": "^11.0.0",
    "firebase-admin": "^13.0.0",
    "react": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "firebase": {
      "optional": true
    },
    "firebase-admin": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^4.0.1",
    "@types/react": "^19.0.0",
    "firebase": "^11.0.0",
    "react": "^19.1.0",
    "typescript": "~5.8.3",
    "vitest": "^4.0.15"
  }
}
