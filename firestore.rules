rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() { return request.auth != null; }
    function isOwner(userId) { return isAuthenticated() && request.auth.uid == userId; }
    function isAppAdmin() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
    function isVillageAdmin(municipalityId) {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/municipalities/$(municipalityId)/members/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/municipalities/$(municipalityId)/members/$(request.auth.uid)).data.role == 'admin';
    }
    function isVillageMember(municipalityId) {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/municipalities/$(municipalityId)/members/$(request.auth.uid));
    }
    function isOrgMember(orgId) {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/organizations/$(orgId)/members/$(request.auth.uid));
    }
    function orgMunicipalityId(orgId) {
      return get(/databases/$(database)/documents/organizations/$(orgId)).data.municipalityId;
    }
    // Organizer of an event: a member of the event's owning org, a village admin
    // of the event's municipality, or an app admin. Used to gate the attendee
    // roster (check-in, remove, organizer-only phone contacts).
    function isEventOrganizer(eventId) {
      return isAuthenticated() && (
        isAppAdmin()
        || isOrgMember(get(/databases/$(database)/documents/events/$(eventId)).data.organizationId)
        || isVillageAdmin(get(/databases/$(database)/documents/events/$(eventId)).data.municipalityId)
      );
    }
    function isTrustedNewsAuthor(municipalityId) {
      return isAuthenticated()
        && exists(/databases/$(database)/documents/municipalities/$(municipalityId)/members/$(request.auth.uid))
        && get(/databases/$(database)/documents/municipalities/$(municipalityId)/members/$(request.auth.uid)).data.trustedNewsAuthor == true;
    }

    // ── Shape validation helpers ─────────────────────────────────────────
    // These mirror the Zod schemas in packages/shared/src/models/*. Any
    // change to a model must update the matching helper here. The CI grep
    // gate in scripts/check-no-raw-collection.mjs enforces typed-ref usage
    // in code, but rules are the only defense against direct console writes
    // or any path that forgets to use a typed ref.
    //
    // Shape predicates check:
    //   - hasOnly([...])  — no unknown keys
    //   - hasAll([...])   — required keys present
    //   - type checks     — critical fields have the right runtime type
    //
    // A `safeParse` derivation script (scripts/audit-firestore-shapes.ts —
    // todo) walks production data and reports any docs that would fail
    // strict converter parse. Run it before each beta promotion.

    function isString(v) { return v is string; }
    function isStringOrNull(v) { return v == null || v is string; }
    function isNumberOrNull(v) { return v == null || v is number; }
    function isBool(v) { return v is bool; }
    function isTimestamp(v) { return v is timestamp; }
    function isTimestampOrNull(v) { return v == null || v is timestamp; }
    function isList(v) { return v is list; }
    function isMap(v) { return v is map; }
    function isMapOrNull(v) { return v == null || v is map; }

    function isValidPartialDate(v) {
      return v == null || (
        v is map
        && v.keys().hasOnly(['year', 'month', 'day'])
        && v.keys().hasAll(['year', 'month', 'day'])
        && (v.year == null || v.year is number)
        && (v.month == null || v.month is number)
        && (v.day == null || v.day is number)
      );
    }

    function isValidReactionCounts(v) {
      return v is map
        && v.keys().hasOnly(['like', 'heart'])
        && v.keys().hasAll(['like', 'heart'])
        && v.like is number
        && v.heart is number;
    }

    // ── Per-collection shape predicates (create payloads) ────────────────

    // /users/{userId} on create: clients omit `displayName` (the
    // syncPersonDenormalization function fills it). All other UserData
    // fields must be present.
    function hasValidUserFields(d) {
      return isString(d.email)
          && isStringOrNull(d.telephone)
          && isStringOrNull(d.activeMunicipalityId)
          && isStringOrNull(d.personId)
          && isValidPartialDate(d.birthday)
          && isStringOrNull(d.biography)
          && isStringOrNull(d.photoURL)
          && isTimestamp(d.createdAt);
    }

    function isValidUserCreate(d) {
      return d.keys().hasOnly([
              'email', 'telephone', 'activeMunicipalityId', 'personId',
              'birthday', 'biography', 'photoURL', 'createdAt',
            ])
          && d.keys().hasAll([
              'email', 'telephone', 'activeMunicipalityId', 'personId',
              'birthday', 'biography', 'photoURL', 'createdAt',
            ])
          && hasValidUserFields(d);
    }

    // /users/{userId} on update: same field set as create minus `displayName`
    // (denormalized by the Cloud Function; clients must never touch it).
    function isValidUserUpdateKeys(affected) {
      return affected.hasOnly([
        'email', 'telephone', 'activeMunicipalityId', 'personId',
        'birthday', 'biography', 'photoURL',
      ]);
    }

    // Onboarding race: createPerson() fires syncPersonDenormalization, which
    // pre-creates users/{uid} carrying only `displayName`. The client's
    // subsequent createUserProfile() setDoc(merge) then lands on the UPDATE
    // path and carries `createdAt`. Allow that one-time set — but only when no
    // createdAt exists yet (it stays immutable afterwards) and the merged
    // fields validate. `displayName` is excluded from the affected keys, so a
    // client still can't overwrite it on this path.
    function isOnboardingUserMerge(reqData, resData) {
      return !('createdAt' in resData)
          && reqData.diff(resData).affectedKeys().hasOnly([
               'email', 'telephone', 'activeMunicipalityId', 'personId',
               'birthday', 'biography', 'photoURL', 'createdAt',
             ])
          && hasValidUserFields(reqData);
    }

    function isValidNewsPostCreate(d) {
      return d.keys().hasOnly([
              'municipalityId', 'authorUserId', 'authorOrgId', 'title', 'body',
              'category', 'images', 'status', 'rejectionReason',
              'submittedAt', 'publishedAt', 'createdBy', 'updatedAt',
              'reactionCounts', 'commentCount',
            ])
          && d.keys().hasAll([
              'municipalityId', 'authorUserId', 'authorOrgId', 'title', 'body',
              'category', 'images', 'status', 'rejectionReason',
              'submittedAt', 'publishedAt', 'createdBy', 'updatedAt',
              'reactionCounts', 'commentCount',
            ])
          && isString(d.municipalityId)
          && isString(d.authorUserId)
          && isStringOrNull(d.authorOrgId)
          && isString(d.title)
          && isString(d.body)
          && d.category in ['fiesta', 'tradicion', 'gastronomia', 'historia', 'otro']
          && isList(d.images)
          && d.status in ['pending', 'approved', 'rejected']
          && isStringOrNull(d.rejectionReason)
          && isTimestamp(d.submittedAt)
          && isTimestampOrNull(d.publishedAt)
          && isString(d.createdBy)
          && isTimestamp(d.updatedAt)
          && isValidReactionCounts(d.reactionCounts)
          && d.commentCount is number;
    }

    function isValidNewsCommentCreate(d) {
      return d.keys().hasOnly([
              'postId', 'municipalityId', 'authorUserId', 'body', 'createdAt', 'hidden',
            ])
          && d.keys().hasAll([
              'postId', 'municipalityId', 'authorUserId', 'body', 'createdAt', 'hidden',
            ])
          && isString(d.postId)
          && isString(d.municipalityId)
          && isString(d.authorUserId)
          && isString(d.body)
          && isTimestamp(d.createdAt)
          && isBool(d.hidden);
    }

    function isValidNewsReactionWrite(d) {
      return d.keys().hasOnly(['postId', 'municipalityId', 'userId', 'kind', 'createdAt'])
          && d.keys().hasAll(['postId', 'municipalityId', 'userId', 'kind', 'createdAt'])
          && isString(d.postId)
          && isString(d.municipalityId)
          && isString(d.userId)
          && d.kind in ['like', 'heart']
          && isTimestamp(d.createdAt);
    }

    function isValidNewsReportCreate(d) {
      return d.keys().hasOnly([
              'targetType', 'targetId', 'postId', 'municipalityId',
              'reporterUserId', 'reason', 'createdAt', 'status',
              'resolvedBy', 'resolvedAt',
            ])
          && d.keys().hasAll([
              'targetType', 'targetId', 'postId', 'municipalityId',
              'reporterUserId', 'reason', 'createdAt', 'status',
              'resolvedBy', 'resolvedAt',
            ])
          && d.targetType in ['comment']
          && isString(d.targetId)
          && isString(d.postId)
          && isString(d.municipalityId)
          && isString(d.reporterUserId)
          && isString(d.reason)
          && isTimestamp(d.createdAt)
          && d.status in ['open', 'dismissed', 'actioned']
          && isStringOrNull(d.resolvedBy)
          && isTimestampOrNull(d.resolvedAt);
    }

    function isValidPersonCreate(d) {
      return d.keys().hasOnly([
              'givenName', 'middleNames', 'firstSurname', 'secondSurname',
              'nickname', 'sex', 'birthday', 'deathDate', 'birthPlace',
              'burialPlace', 'municipalityLinks', 'occupationIds',
              'pendingOccupations', 'biography', 'photoURL', 'userId',
              'createdBy', 'createdAt',
            ])
          && d.keys().hasAll([
              'givenName', 'middleNames', 'firstSurname', 'secondSurname',
              'nickname', 'sex', 'birthday', 'deathDate', 'birthPlace',
              'burialPlace', 'municipalityLinks', 'occupationIds',
              'pendingOccupations', 'biography', 'photoURL', 'userId',
              'createdBy', 'createdAt',
            ])
          && isString(d.givenName)
          && isList(d.middleNames)
          && isStringOrNull(d.firstSurname)
          && isStringOrNull(d.secondSurname)
          && isStringOrNull(d.nickname)
          && (d.sex == null || d.sex in ['male', 'female', 'other'])
          && isValidPartialDate(d.birthday)
          && isValidPartialDate(d.deathDate)
          && isMapOrNull(d.birthPlace)
          && isMapOrNull(d.burialPlace)
          && isList(d.municipalityLinks)
          && isList(d.occupationIds)
          && isList(d.pendingOccupations)
          && isStringOrNull(d.biography)
          && isStringOrNull(d.photoURL)
          && isStringOrNull(d.userId)
          && isString(d.createdBy)
          && isTimestamp(d.createdAt);
    }

    function isValidOrganizationCreate(d) {
      return d.keys().hasOnly([
              'name', 'description', 'imageURL', 'type', 'status', 'municipalityId',
              'requestedBy', 'approvedBy', 'createdAt', 'decidedAt',
            ])
          && d.keys().hasAll([
              'name', 'description', 'imageURL', 'type', 'status', 'municipalityId',
              'requestedBy', 'approvedBy', 'createdAt', 'decidedAt',
            ])
          && isString(d.name)
          && isStringOrNull(d.description)
          && isStringOrNull(d.imageURL)
          && d.type in ['ayuntamiento', 'peña', 'asociación']
          && d.status in ['pending', 'approved', 'rejected']
          && isString(d.municipalityId)
          && isString(d.requestedBy)
          && isStringOrNull(d.approvedBy)
          && isTimestamp(d.createdAt)
          && isTimestampOrNull(d.decidedAt);
    }

    function isValidOccupationProposalCreate(d) {
      return d.keys().hasOnly([
              'name', 'proposedBy', 'proposedAt', 'status',
              'reviewedBy', 'reviewedAt', 'approvedOccupationId',
            ])
          && d.keys().hasAll([
              'name', 'proposedBy', 'proposedAt', 'status',
              'reviewedBy', 'reviewedAt', 'approvedOccupationId',
            ])
          && isString(d.name)
          && isString(d.proposedBy)
          && isTimestamp(d.proposedAt)
          && d.status in ['pending', 'approved', 'rejected']
          && isStringOrNull(d.reviewedBy)
          && isTimestampOrNull(d.reviewedAt)
          && isStringOrNull(d.approvedOccupationId);
    }

    function isValidPlaceProposalCreate(d) {
      return d.keys().hasOnly([
              'name', 'kind', 'description', 'municipalityId', 'imageURL',
              'createdAt', 'status', 'proposedBy', 'approvedBy', 'decidedAt',
            ])
          && d.keys().hasAll([
              'name', 'kind', 'description', 'municipalityId', 'imageURL',
              'createdAt', 'status', 'proposedBy', 'approvedBy', 'decidedAt',
            ])
          && isString(d.name)
          && d.kind in ['cemetery', 'church', 'hermitage', 'plaza', 'town_hall']
          && isStringOrNull(d.description)
          && isString(d.municipalityId)
          && isStringOrNull(d.imageURL)
          && isTimestamp(d.createdAt)
          && d.status in ['pending', 'approved', 'rejected']
          && isStringOrNull(d.proposedBy)
          && isStringOrNull(d.approvedBy)
          && isTimestampOrNull(d.decidedAt);
    }

    function isValidBarrioProposalCreate(d) {
      return d.keys().hasOnly([
              'name', 'municipalityId', 'imageURL', 'createdAt',
              'status', 'proposedBy', 'approvedBy', 'decidedAt',
            ])
          && d.keys().hasAll([
              'name', 'municipalityId', 'imageURL', 'createdAt',
              'status', 'proposedBy', 'approvedBy', 'decidedAt',
            ])
          && isString(d.name)
          && isString(d.municipalityId)
          && isStringOrNull(d.imageURL)
          && isTimestamp(d.createdAt)
          && d.status in ['pending', 'approved', 'rejected']
          && isStringOrNull(d.proposedBy)
          && isStringOrNull(d.approvedBy)
          && isTimestampOrNull(d.decidedAt);
    }

    function isValidEventCreate(d) {
      return d.keys().hasOnly([
              'title', 'description', 'startDate', 'endDate', 'location',
              'imageURL', 'maxAttendees', 'telephoneRequired',
              'status', 'organizationId', 'organizationName', 'createdBy',
              'createdAt', 'updatedAt', 'municipalityId', 'municipalityName',
              'municipalityCoverImage', 'municipalityCoordinates',
              'confirmedCount', 'totalCount',
            ])
          && d.keys().hasAll([
              'title', 'description', 'startDate', 'endDate', 'location',
              'imageURL', 'maxAttendees', 'telephoneRequired',
              'status', 'organizationId', 'organizationName', 'createdBy',
              'createdAt', 'updatedAt', 'municipalityId', 'municipalityName',
              'municipalityCoverImage', 'municipalityCoordinates',
            ])
          && isString(d.title)
          && isString(d.description)
          && isTimestamp(d.startDate)
          && isTimestampOrNull(d.endDate)
          && isMap(d.location)
          && isStringOrNull(d.imageURL)
          && isNumberOrNull(d.maxAttendees)
          && isBool(d.telephoneRequired)
          && d.status in ['published', 'cancelled', 'completed']
          && isString(d.organizationId)
          && isString(d.organizationName)
          && isString(d.createdBy)
          && isTimestamp(d.createdAt)
          && isTimestamp(d.updatedAt)
          && isString(d.municipalityId)
          && isString(d.municipalityName)
          && isStringOrNull(d.municipalityCoverImage)
          && isMapOrNull(d.municipalityCoordinates);
    }

    // ── Collections ──────────────────────────────────────────────────────

    match /news/{postId} {
      // Approved posts are public (parity with published events) so the
      // cross-village Explora feed can list them. Pending/rejected posts stay
      // visible only to members of the post's own village (moderation + author).
      allow read: if resource.data.status == 'approved'
                    || isVillageMember(resource.data.municipalityId);
      allow create: if isVillageMember(request.resource.data.municipalityId)
                      && isValidNewsPostCreate(request.resource.data)
                      && request.resource.data.authorUserId == request.auth.uid
                      && request.resource.data.createdBy == request.auth.uid
                      && request.resource.data.publishedAt == null
                      && request.resource.data.reactionCounts.like == 0
                      && request.resource.data.reactionCounts.heart == 0
                      && request.resource.data.commentCount == 0
                      && (
                        request.resource.data.status == 'pending'
                        || (request.resource.data.status == 'approved'
                            && isTrustedNewsAuthor(request.resource.data.municipalityId))
                      );
      allow update: if isOwner(resource.data.createdBy)
                      && !request.resource.data.diff(resource.data).affectedKeys().hasAny([
                           'status','publishedAt','authorUserId','authorOrgId',
                           'municipalityId','submittedAt','createdBy',
                           'reactionCounts','commentCount'
                         ]);
      allow delete: if false;
    }

    match /newsComments/{commentId} {
      allow read: if isVillageMember(resource.data.municipalityId);
      allow create: if isVillageMember(request.resource.data.municipalityId)
                      && isValidNewsCommentCreate(request.resource.data)
                      && request.resource.data.authorUserId == request.auth.uid
                      && request.resource.data.hidden == false;
      allow update: if false;
      allow delete: if isOwner(resource.data.authorUserId);
    }

    match /newsReactions/{reactionId} {
      allow read: if isVillageMember(resource.data.municipalityId);
      allow create, update: if isVillageMember(request.resource.data.municipalityId)
                              && isValidNewsReactionWrite(request.resource.data)
                              && request.resource.data.userId == request.auth.uid
                              && reactionId == request.resource.data.postId + '_' + request.auth.uid;
      allow delete: if isOwner(resource.data.userId);
    }

    match /newsReports/{reportId} {
      allow read: if isVillageAdmin(resource.data.municipalityId)
                    || isOwner(resource.data.reporterUserId)
                    || isAppAdmin();
      allow create: if isVillageMember(request.resource.data.municipalityId)
                      && isValidNewsReportCreate(request.resource.data)
                      && request.resource.data.reporterUserId == request.auth.uid
                      && request.resource.data.status == 'open'
                      && request.resource.data.resolvedBy == null
                      && request.resource.data.resolvedAt == null;
      allow update, delete: if false;
    }

    match /admins/{userId} {
      allow read: if isOwner(userId) || isAppAdmin();
      allow write: if false;
    }

    match /users/{userId} {
      allow read: if true;
      // displayName is denormalized from persons/{id} by the
      // syncPersonDenormalization Cloud Function — clients must not touch it.
      allow create: if isOwner(userId)
                    && !request.resource.data.keys().hasAny(['displayName'])
                    && isValidUserCreate(request.resource.data);
      allow update: if isOwner(userId)
                    && (
                         isValidUserUpdateKeys(
                           request.resource.data.diff(resource.data).affectedKeys()
                         )
                         || isOnboardingUserMerge(request.resource.data, resource.data)
                       );
      allow delete: if false;

      match /notifications/{notifId} {
        allow read: if isOwner(userId);
        allow update: if isOwner(userId)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
        allow create, delete: if false;
      }
    }

    // municipalities: reference data + optional community overlay.
    // Reference fields are superadmin-only; community fields are managed by
    // the village admin once activated. Shape is not enforced here because
    // these writes only happen via the seed script + village admin UI, both
    // of which go through the typed converter; adding hasOnly() here would
    // require updating every admin script.
    match /municipalities/{municipalityId} {
      allow read: if true;
      // Only superadmin can create the base municipality record (the seed
      // script runs with admin credentials).
      allow create: if isAppAdmin();
      // Updates: village admins can edit the community subfield + coordinates;
      // superadmin can edit anything; nobody else can write.
      allow update: if isAppAdmin() || isVillageAdmin(municipalityId);
      allow delete: if isAppAdmin();

      // Propose-pending: any village member may create a `pending` barrio
      // (visible to all); organizers (village/app admin) create directly and
      // approve/reject. A proposer may edit/withdraw their own still-pending one.
      match /barrios/{barrioId} {
        allow read: if true;
        allow create: if isAppAdmin()
          || isVillageAdmin(municipalityId)
          || (
               isVillageMember(municipalityId)
               && isValidBarrioProposalCreate(request.resource.data)
               && request.resource.data.status == 'pending'
               && request.resource.data.proposedBy == request.auth.uid
             );
        allow update: if isVillageAdmin(municipalityId) || isAppAdmin()
          || (
               isOwner(resource.data.proposedBy)
               && resource.data.status == 'pending'
               && request.resource.data.status == 'pending'
             );
        allow delete: if isVillageAdmin(municipalityId) || isAppAdmin()
          || (isOwner(resource.data.proposedBy) && resource.data.status == 'pending');
      }

      match /places/{placeId} {
        allow read: if true;
        allow create: if isAppAdmin()
          || isVillageAdmin(municipalityId)
          || (
               isVillageMember(municipalityId)
               && isValidPlaceProposalCreate(request.resource.data)
               && request.resource.data.status == 'pending'
               && request.resource.data.proposedBy == request.auth.uid
             );
        allow update: if isVillageAdmin(municipalityId) || isAppAdmin()
          || (
               isOwner(resource.data.proposedBy)
               && resource.data.status == 'pending'
               && request.resource.data.status == 'pending'
             );
        allow delete: if isVillageAdmin(municipalityId) || isAppAdmin()
          || (isOwner(resource.data.proposedBy) && resource.data.status == 'pending');
      }

      match /members/{userId} {
        allow read: if true;
        allow create: if isVillageAdmin(municipalityId) || isAppAdmin();
        allow update: if (
                         (isVillageAdmin(municipalityId) || isAppAdmin())
                         && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['trustedNewsAuthor'])
                       )
                       || (isOwner(userId)
                           && request.resource.data.diff(resource.data).affectedKeys()
                              .hasOnly(['profileAnswers', 'profileCompletedAt']));
        allow delete: if isVillageAdmin(municipalityId) || isAppAdmin() || isOwner(userId);
      }

      match /inviteTokens/{tokenId} {
        allow read: if true;
        allow create: if isVillageAdmin(municipalityId) || isAppAdmin();
        // acceptInvite Cloud Function handles redemption via admin SDK.
        allow update: if false;
        allow delete: if isVillageAdmin(municipalityId) || isAppAdmin();
      }

      match /joinRequests/{userId} {
        // Single-doc get: requester, village admin of that muni, or app admin.
        allow get: if isAuthenticated()
          && (request.auth.uid == userId
              || isVillageAdmin(municipalityId)
              || isAppAdmin());
        // Per-municipality list (village admin moderation UI / app admin).
        allow list: if isAuthenticated()
          && (isVillageAdmin(municipalityId) || isAppAdmin());
        // Cloud Functions (admin SDK) own create/update/delete.
        allow create, update, delete: if false;
      }
    }

    // Collection-group self-list for joinRequests. Required because
    // Firestore's v2 list-rule analyzer can't safely union the nested
    // match path above with collection-group queries that include
    // `get()`/`exists()` calls in OR branches. This block applies only
    // when the query filters on `userId == auth.uid`.
    match /{path=**}/joinRequests/{userId} {
      allow list: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
    }

    match /organizerRequests/{requestId} {
      allow read: if isAuthenticated()
        && (resource.data.userId == request.auth.uid || isAppAdmin());
      // Cloud Functions (admin SDK) own create/update/delete.
      allow create, update, delete: if false;
    }

    match /organizations/{orgId} {
      allow read: if true;
      // ayuntamiento is a singleton per village — created only via the
      // requestAyuntamiento callable (admin SDK), which enforces the cap in a
      // transaction. peña / asociación are unlimited and created client-side.
      allow create: if isAuthenticated()
        && (isVillageMember(request.resource.data.municipalityId) || isAppAdmin())
        && isValidOrganizationCreate(request.resource.data)
        && request.resource.data.status == 'pending'
        && request.resource.data.type != 'ayuntamiento';
      allow update: if isVillageAdmin(resource.data.municipalityId) || isAppAdmin();
      allow delete: if isVillageAdmin(resource.data.municipalityId) || isAppAdmin();

      match /members/{userId} {
        allow read: if true;
        allow create: if isOrgMember(orgId)
          || isVillageAdmin(orgMunicipalityId(orgId))
          || isAppAdmin();
        allow update: if false;
        allow delete: if isOwner(userId)
          || isVillageAdmin(orgMunicipalityId(orgId))
          || isAppAdmin();
      }
    }

    match /events/{eventId} {
      allow read: if true;
      allow create: if isAuthenticated()
        && isOrgMember(request.resource.data.organizationId)
        && isValidEventCreate(request.resource.data)
        && request.resource.data.municipalityId is string;
      allow update: if isOrgMember(resource.data.organizationId)
        || isVillageAdmin(resource.data.municipalityId)
        || isAppAdmin();
      allow delete: if isOrgMember(resource.data.organizationId)
        || isVillageAdmin(resource.data.municipalityId)
        || isAppAdmin();

      match /registrations/{regId} {
        allow read: if true;
        // Creation goes through the `registerToEvent` callable (admin SDK
        // bypasses rules). Direct client writes are not trusted because the
        // capacity/waitlist decision must be made server-side in a
        // transaction.
        allow create: if false;
        // Self may update/cancel their own registration; an organizer may too
        // (check-in via `checkedInAt`, or removing a no-show / walk-in).
        allow update: if (isAuthenticated() && resource.data.userId == request.auth.uid)
          || isEventOrganizer(eventId);
        allow delete: if (isAuthenticated() && resource.data.userId == request.auth.uid)
          || isEventOrganizer(eventId);
      }

      // Organizer-only attendee phone contacts (the registration doc itself is
      // public, so phones live here). Written only by callables (admin SDK).
      match /registrationContacts/{regId} {
        allow read: if isEventOrganizer(eventId);
        allow write: if false;
      }
    }

    // persons — canonical people registry
    match /persons/{personId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && isValidPersonCreate(request.resource.data)
        && request.resource.data.createdBy == request.auth.uid;
      allow update: if isAuthenticated()
        && (
          resource.data.userId == request.auth.uid
          || (resource.data.createdBy == request.auth.uid && resource.data.userId == null)
          || isAppAdmin()
        );
      allow delete: if isAuthenticated()
        && (
          (resource.data.createdBy == request.auth.uid && resource.data.userId == null)
          || isAppAdmin()
        );
    }

    // Collection-group queries: allow authenticated users to list only their
    // own rows. These rules are evaluated for CG list operations on the named
    // sub-collection regardless of which parent collection they live under.
    // "allow read: if true" on nested paths allows single-doc gets but does
    // NOT satisfy list operations on a collection-group in Firestore Rules v2.

    match /{path=**}/members/{userId} {
      allow list: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
    }

    match /{path=**}/registrations/{regId} {
      allow list: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
    }

    match /{path=**}/joinRequests/{userId} {
      allow list: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
    }

    // occupations — superadmin managed list
    match /occupations/{occupationId} {
      allow read: if true;
      allow write: if isAppAdmin();
    }

    // occupationProposals — users propose, superadmin reviews
    match /occupationProposals/{proposalId} {
      allow read: if isOwner(resource.data.proposedBy) || isAppAdmin();
      allow create: if isAuthenticated()
        && isValidOccupationProposalCreate(request.resource.data)
        && request.resource.data.proposedBy == request.auth.uid
        && request.resource.data.status == 'pending';
      allow update: if isAppAdmin();
      allow delete: if isOwner(resource.data.proposedBy) || isAppAdmin();
    }
  }
}
